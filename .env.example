APP_NAME=InterviewPilot
APP_VERSION=0.1.0
API_PREFIX=/api
API_VERSION=v1
DEBUG=true
SECRET_KEY=please-change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
DATABASE_URL=sqlite+aiosqlite:///./temps/interview_pilot.db

# 学习阶段默认可以用 memory，方便不启动 Redis 也能跑项目和测试。
# 需要真实 Redis 时改成 redis，并启动 deploy/docker-compose.yml 中的 redis 服务。
REDIS_URL=redis://localhost:6379/0
CACHE_BACKEND=memory
DASHBOARD_CACHE_TTL_SECONDS=300
MESSAGE_QUEUE_BACKEND=memory
MESSAGE_QUEUE_NAME=interview_pilot:events
ENABLE_BACKGROUND_WORKER=true
